# ── Flask ──────────────────────────────────────────────────────────────────
# Generate a strong random value for production (e.g. `python -c "import secrets;print(secrets.token_hex(32))"`).
SECRET_KEY=
DEBUG=True
PREFERRED_URL_SCHEME=http

# Set to True only when serving over HTTPS (production). Leave False for local HTTP.
SESSION_COOKIE_SECURE=False

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/tourism_db

# ── Tour API / Local LLM (Ollama) ────────────────────────────────────────────
TOUR_API_KEY=
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=gemma4:26b

# ── Google OAuth (OpenID Connect) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Kakao Login (OpenID Connect) ─────────────────────────────────────────────
# KAKAO_CLIENT_ID is the Kakao REST API key. KAKAO_CLIENT_SECRET is optional and
# only required when the Kakao application enables a client secret.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
